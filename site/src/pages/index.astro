---
import Base from '../layouts/Base.astro';
---

<Base title="Teaching That Sticks" bodyClass="home-page" currentNav="home" brandRole="Get Started">

  <fragment slot="head">
    <style>
      .hero {
        min-height: calc(100dvh - 60px);
        padding-top: 3.25rem;
        padding-bottom: 2.5rem;
        padding-left: 2.5rem;
        padding-right: 2.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 3rem;
        position: relative;
      }
      .hero-split {
        width: 100%;
        max-width: 960px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 2.5rem;
      }
      .hero-text {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        text-align: right;
        gap: 1.25rem;
        min-width: 0;
        overflow-wrap: break-word;
      }
      .headline {
        font-family: 'Playfair Display', Georgia, serif;
        font-size: clamp(3.25rem, 5.5vw, 6rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.03em;
        color: var(--text);
      }
      .subtitle {
        font-size: clamp(0.9rem, 1.8vw, 1.1rem);
        font-weight: 300;
        color: var(--subtext1);
        max-width: 46ch;
        line-height: 1.8;
      }
      .hero-mascot {
        display: flex;
        justify-content: center;
        align-items: flex-end;
        min-width: 0;
      }
      #hero-fox {
        width: 100%;
        max-width: 529px;
        opacity: 0;
        pointer-events: none;
        user-select: none;
      }
      .hero-ctas {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--peach);
        padding: 0.6rem 1.4rem;
        border: 2px solid var(--peach);
        border-radius: 8px;
        text-decoration: none;
        letter-spacing: 0.01em;
        transition: background 0.18s, color 0.18s;
      }
      .hero-cta:visited { color: var(--peach); }
      .hero-cta:hover { background: var(--peach); color: var(--base); }
      .hero-cta--ghost {
        color: var(--subtext0);
        border-color: var(--surface0);
      }
      .hero-cta--ghost:visited { color: var(--subtext0); }
      .hero-cta--ghost:hover {
        background: var(--surface0);
        color: var(--text);
        border-color: var(--overlay0);
      }
      @media (max-width: 860px) {
        .hero-split { grid-template-columns: 1fr; }
        .hero-mascot { order: -1; }
        #hero-fox { max-width: 200px; }
        .hero-text { align-items: center; text-align: center; }
      }
      @media (max-width: 520px) {
        .hero { gap: 2rem; padding-bottom: 4.5rem; }
        .headline { font-size: clamp(2.75rem, 12vw, 5rem); }
      }
    </style>
  </fragment>

  <section class="hero">
    <div class="hero-split">
      <div class="hero-text">
        <h1 class="headline">Teaching<br />That&nbsp;Sticks</h1>
        <p class="subtitle">
          A free, open&#8209;source development programme —
          clinical teaching grounded in the best of learning science.
        </p>
      </div>
      <div class="hero-mascot">
        <img id="hero-fox" src="/images/fox/whiteboard.png" alt="" aria-hidden="true" />
      </div>
    </div>
    <div class="hero-ctas">
      <a class="hero-cta hero-cta--ghost" href="/about">About this project</a>
      <a class="hero-cta" href="/sessions">Get Started &#x2192;</a>
    </div>
  </section>

  <fragment slot="scripts">
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        (window as any).anime({
          targets: '#hero-fox',
          opacity:    [0, 1],
          translateY: [28, 0],
          duration:   900,
          delay:      350,
          easing:     'easeOutCubic',
        });
      });
    </script>
  </fragment>

</Base>
