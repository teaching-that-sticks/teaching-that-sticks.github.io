---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const papers = await getCollection('papers');

// Sort by year descending
const sorted = [...papers].sort((a, b) => b.data.year - a.data.year);
---

<Base
  title="Evidence Base — Teaching That Sticks"
  bodyClass="session-page library-page"
  currentNav="theories"
  brandRole="Theory Library"
  brandRoleClass="brand-role--green"
>

  <section class="library-section">
    <div class="library-inner">
      <div class="library-hero-inner">
        <div class="library-hero-text">
          <div class="library-overline">The Evidence Base</div>
          <h1 class="library-title">Research summaries</h1>
          <p class="library-lede">
            Plain-English summaries and honest critical reviews of the key papers behind
            Teaching That Sticks. Each summary covers what the study did, what it found,
            its limitations, and what it means for clinical education.
            <a href="/theories">Browse the theory library →</a>
          </p>
        </div>
        <img class="library-fox" src="/images/fox/reading.png" alt="Fox reading" />
      </div>

      <div class="theory-list" style="margin-top:2rem;">
        {sorted.map((paper) => (
          <div class="theory-card">
            <div class="theory-card-main">
              <div class="theory-card-name">{paper.data.title}</div>
              <div class="theory-card-summary">
                {paper.data.authors.split(',')[0]} · {paper.data.journal} · {paper.data.year}
              </div>
            </div>
            <div class="theory-card-action">
              <a class="theory-card-link" href={`/papers/${paper.id}`}>Read →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Base>
