---
/**
 * src/pages/theories/index.astro — Theory Library listing
 * Groups theories by session, matching the prototype layout.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

// Sessions in order; theories in the order each session lists them
const sessions = await getCollection('sessions');
sessions.sort((a, b) => a.data.number - b.data.number);

const allTheories = await getCollection('theories');
const theoryMap = Object.fromEntries(allTheories.map(t => [t.id, t]));
---

<Base title="Theory Library" bodyClass="session-page" currentNav="theories" brandRole="Theory Library" brandRoleClass="brand-role--green">

  <main class="library-section">
    <div class="library-inner">

      <!-- Hero -->
      <div class="library-hero-inner">
        <div class="library-hero-text">
          <p class="library-overline">The Theory Library</p>
          <h1 class="library-title">The evidence behind the teaching</h1>
          <p class="library-lede">
            Plain-language overviews of the 15 concepts that underpin the
            programme — each with links to the original research so you can
            go deeper. <a href="/papers">Read the evidence summaries →</a>
          </p>
        </div>
        <img
          id="library-fox"
          class="library-fox"
          src="/images/fox/reading.png"
          alt=""
          aria-hidden="true"
          style="opacity:0;"
        />
      </div>

      <!-- Session groups -->
      {sessions.map(session => {
        const theories = (session.data.theories ?? [])
          .map(id => theoryMap[id])
          .filter(Boolean);
        if (theories.length === 0) return null;
        return (
          <div class="theory-group">
            <p class="theory-group-session">Session {session.data.number}</p>
            <h2 class="theory-group-title">{session.data.tagline}</h2>
            <div class="theory-list" data-animate>
              {theories.map(t => (
                <div class="theory-card">
                  <div class="theory-card-main">
                    <p class="theory-card-name">{t.data.title}</p>
                    <p class="theory-card-summary">{t.data.summary}</p>
                  </div>
                  <div class="theory-card-action">
                    <a class="theory-card-link" href={`/theories/${t.id}`}>Read →</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}

    </div>
  </main>

  <fragment slot="scripts">
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const fox = document.getElementById('library-fox') as HTMLImageElement | null;
        if (!fox) return;
        const animeFn = (window as any).anime ?? null;
        if (!animeFn) { fox.style.opacity = '1'; return; }
        animeFn({
          targets: fox,
          opacity: [0, 1],
          translateY: [20, 0],
          duration: 800,
          easing: 'easeOutCubic',
          delay: 300,
        });
      });
    </script>
  </fragment>

</Base>
